// datasource menentukan koneksi ke database Anda.
// Anda dapat mengganti provider ke "mysql" atau "postgresql" sesuai kebutuhan stack Anda.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS (Tipe Data Konstan)
// ==========================================

enum Role {
  SUPER_ADMIN
  UNIT_ADMIN
  WALI_KELAS
  PARENT
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum InvoiceType {
  SPP
  EKSTRAKURIKULER
  KEGIATAN
  LAINNYA
}

enum InvoiceStatus {
  PENDING
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  MIDTRANS
  TRANSFER
}

// ==========================================
// DATA MASTER
// ==========================================

model SchoolUnit {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(50) // Contoh: "RA", "TK", "SD"

  // Relasi (Satu Unit Sekolah memiliki banyak relasi di bawah ini)
  users        User[]
  students     Student[]
  transactions Transaction[]
  categories   Category[]
  sppTariffs   SppTariff[]

  @@map("school_units")
}

model User {
  id           Int         @id @default(autoincrement())
  name         String      @db.VarChar(255)
  email        String      @unique @db.VarChar(255)
  phoneNumber  String?     @unique @map("phone_number") @db.VarChar(20)
  password     String      @db.VarChar(255)
  role         Role
  schoolUnitId Int?        @map("school_unit_id")
  schoolUnit   SchoolUnit?   @relation(fields: [schoolUnitId], references: [id])
  className    String?     @map("class_name") @db.VarChar(50)
  transactions Transaction[] @relation("RecorderToTransactions")
  students     Student[]     @relation("ParentToStudents")

  @@map("users")
}

model SppTariff {
  id             Int @id @default(autoincrement())
  schoolUnitId   Int @map("school_unit_id")
  enrollmentYear Int @map("enrollment_year") // Tahun angkatan masuk (contoh: 2024, 2025)
  amount         Int // Tarif dasar SPP bulanan dalam Rupiah (Gunakan Int karena IDR tidak memiliki sen)

  // Relasi
  // Jika unit sekolah dihapus, otomatis hapus master tarif terkait
  schoolUnit SchoolUnit @relation(fields: [schoolUnitId], references: [id], onDelete: Cascade)

  // Composite Unique Key: Mencegah duplikasi entri tarif untuk Unit & Angkatan yang sama
  @@unique([schoolUnitId, enrollmentYear], name: "uq_school_unit_enrollment_year")
  @@map("spp_tariffs")
}

model Student {
  id                 Int         @id @default(autoincrement())
  studentNumber      String      @unique @map("student_number") @db.VarChar(50) // NIS / Nomor Induk Siswa
  name               String      @db.VarChar(255)
  className          String      @map("class_name") @db.VarChar(50)
  schoolUnitId       Int         @map("school_unit_id")
  parentId           Int         @map("parent_id")
  enrollmentYear     Int         @map("enrollment_year") // Tahun angkatan masuk
  discountPercentage Int         @default(0) @map("discount_percentage") // Persentase diskon (0-100)

  // Relasi
  // Restrict mencegah penghapusan unit/parent jika masih ada data siswa aktif yang terikat dengannya
  schoolUnit         SchoolUnit  @relation(fields: [schoolUnitId], references: [id], onDelete: Restrict)
  parent             User        @relation("ParentToStudents", fields: [parentId], references: [id], onDelete: Restrict)
  invoices           Invoice[]

  @@map("students")
}

model Category {
  id           Int          @id @default(autoincrement())
  name         String       @db.VarChar(100) // Contoh: "BOS", "SPP", "Gaji Guru", "Operasional"
  type         CategoryType
  schoolUnitId Int?         @map("school_unit_id") // Nullable jika kategori ini bersifat global (bisa dipakai semua unit)

  // Relasi
  schoolUnit   SchoolUnit?   @relation(fields: [schoolUnitId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@map("categories")
}

// ==========================================
// DATA TRANSAKSIONAL
// ==========================================

model Invoice {
  id              Int           @id @default(autoincrement())
  studentId       Int           @map("student_id")
  invoiceType     InvoiceType   @map("invoice_type")
  month           Int // Bulan tagihan (1-12)
  year            Int // Tahun tagihan (e.g. 2026)
  baseAmount      Int           @map("base_amount") // Tarif dasar riil saat tagihan di-generate (snapshot dari spp_tariffs)
  discountApplied Int           @map("discount_applied") // Hasil hitung potongan dalam rupiah
  amount          Int // Bersih akhir yang harus dibayarkan siswa (baseAmount - discountApplied)
  status          InvoiceStatus @default(PENDING)
  midtransOrderId String?       @unique @map("midtrans_order_id") @db.VarChar(255)

  // Relasi
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  // Composite Unique Key: Mencegah tagihan ganda untuk jenis, bulan, dan tahun yang sama pada siswa yang sama
  @@unique([studentId, month, year, invoiceType], name: "uq_student_billing_period")
  @@map("invoices")
}

model Transaction {
  id            Int           @id @default(autoincrement())
  date          DateTime      @default(now())
  type          CategoryType // INCOME / EXPENSE
  categoryId    Int           @map("category_id")
  invoiceId     Int?          @map("invoice_id") // Nullable, terisi hanya jika transaksi ini adalah pelunasan tagihan SPP
  paymentMethod PaymentMethod @map("payment_method")
  amount        Int // Nominal uang masuk/keluar. (Ganti BigInt jika kalkulasi akumulasi Anda melewati 2.1 miliar)
  description   String?       @db.Text
  schoolUnitId  Int           @map("school_unit_id")
  recordedById  Int?          @map("recorded_by_id") // Nullable, kosong jika sistem otomatis (seperti webhook Midtrans)

  // Relasi
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  invoice    Invoice?   @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  schoolUnit SchoolUnit @relation(fields: [schoolUnitId], references: [id], onDelete: Restrict)
  recordedBy User?      @relation("RecorderToTransactions", fields: [recordedById], references: [id], onDelete: SetNull)

  @@map("transactions")
}
